<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- 上半部分 - 显示区域 (40%) -->
    <LinearLayout
        android:id="@+id/displayLayout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="bottom"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/buttonLayout"
        app:layout_constraintHeight_percent="0.4">

        <!-- 历史算式的TextView - 允许多行显示 -->
        <TextView
            android:id="@+id/tvExpression"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="bottom|end"
            android:textSize="18sp"
            android:textColor="#888888"
            android:text=""
            android:maxLines="3"
            android:lineSpacingExtra="4dp"
            android:paddingBottom="8dp" />

        <!-- 结果的TextView - 支持水平滚动，右对齐 -->
        <HorizontalScrollView
            android:id="@+id/horizontalScrollView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:fadeScrollbars="false"
            android:overScrollMode="never"
            android:fillViewport="true">

            <TextView
                android:id="@+id/tvResult"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:textSize="48sp"
                android:textColor="#FFFFFF"
                android:text="0"
                android:maxLines="1"
                android:includeFontPadding="false"
                android:paddingEnd="0dp" />
        </HorizontalScrollView>
    </LinearLayout>

    <!-- 下半部分 - 按钮区域 (60%) -->
    <GridLayout
        android:id="@+id/buttonLayout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:rowCount="5"
        android:columnCount="4"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@+id/displayLayout"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintHeight_percent="0.6">

        <!-- 第1行 -->
        <Button
            android:id="@+id/btnClear"
            style="@style/CalculatorButton.Gray"
            android:text="AC" />
        <Button
            android:id="@+id/btnToggleSign"
            style="@style/CalculatorButton.Gray"
            android:text="±" />
        <Button
            android:id="@+id/btnPercent"
            style="@style/CalculatorButton.Gray"
            android:text="%" />
        <Button
            android:id="@+id/btnDivide"
            style="@style/CalculatorButton.Orange"
            android:text="÷" />

        <!-- 第2行 -->
        <Button
            android:id="@+id/btn7"
            style="@style/CalculatorButton.Black"
            android:text="7" />
        <Button
            android:id="@+id/btn8"
            style="@style/CalculatorButton.Black"
            android:text="8" />
        <Button
            android:id="@+id/btn9"
            style="@style/CalculatorButton.Black"
            android:text="9" />
        <Button
            android:id="@+id/btnMultiply"
            style="@style/CalculatorButton.Orange"
            android:text="×" />

        <!-- 第3行 -->
        <Button
            android:id="@+id/btn4"
            style="@style/CalculatorButton.Black"
            android:text="4" />
        <Button
            android:id="@+id/btn5"
            style="@style/CalculatorButton.Black"
            android:text="5" />
        <Button
            android:id="@+id/btn6"
            style="@style/CalculatorButton.Black"
            android:text="6" />
        <Button
            android:id="@+id/btnMinus"
            style="@style/CalculatorButton.Orange"
            android:text="-" />

        <!-- 第4行 -->
        <Button
            android:id="@+id/btn1"
            style="@style/CalculatorButton.Black"
            android:text="1" />
        <Button
            android:id="@+id/btn2"
            style="@style/CalculatorButton.Black"
            android:text="2" />
        <Button
            android:id="@+id/btn3"
            style="@style/CalculatorButton.Black"
            android:text="3" />
        <Button
            android:id="@+id/btnPlus"
            style="@style/CalculatorButton.Orange"
            android:text="+" />

        <!-- 第5行 -->
        <Button
            android:id="@+id/btn0"
            style="@style/CalculatorButton.Zero"
            android:text="0"
            android:layout_columnSpan="2" />
        <Button
            android:id="@+id/btnDot"
            style="@style/CalculatorButton.Black"
            android:text="." />
        <Button
            android:id="@+id/btnEquals"
            style="@style/CalculatorButton.Orange"
            android:text="=" />

    </GridLayout>

</androidx.constraintlayout.widget.ConstraintLayout>